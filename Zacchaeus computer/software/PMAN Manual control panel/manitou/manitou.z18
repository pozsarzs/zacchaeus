	ORG	100h
EXTRN	PMAN
; -- CODE AREA -----------------------------------------------------------------
START:

; (..)

; -- CONSTANTS -----------------------------------------------------------------
BDOS	EQU	005h			; BDOS system call

; -- DATA AREA -----------------------------------------------------------------
ADDR:	DB	0			; I/O address
	END
